#!/usr/bin/env bash
# Configures a brand new Ubuntu server with Nginx and adds custom HTTP response header X-Served-By set to the server hostname

export DEBIAN_FRONTEND=noninteractive
apt-get update -y
apt-get install -y nginx

# Remove any existing X-Served-By header
sed -i '/X-Served-By/d' /etc/nginx/nginx.conf
sed -i '/X-Served-By/d' /etc/nginx/sites-available/default

# Add header with dynamic hostname into the http block
HOSTNAME=$(hostname)
sed -i "s/http {/http {\n\tadd_header X-Served-By $HOSTNAME always;/" /etc/nginx/nginx.conf

if command -v systemctl > /dev/null 2>&1; then
    systemctl restart nginx
else
    service nginx restart
fi
# shellcheck disable=SC2154
