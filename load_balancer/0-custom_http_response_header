#!/usr/bin/env bash
# Configures a brand new Ubuntu server with Nginx and adds custom HTTP response header X-Served-By set to the server hostname

export DEBIAN_FRONTEND=noninteractive
apt-get update -y
apt-get install -y nginx

HOSTNAME=$(hostname)

# Remove old header if exists
sed -i '/X-Served-By/d' /etc/nginx/sites-available/default

# Add header inside the server block
sed -i "s/server_name _;/server_name _;\n\tadd_header X-Served-By $HOSTNAME always;/" /etc/nginx/sites-available/default

if command -v systemctl > /dev/null 2>&1; then
    systemctl restart nginx
else
    service nginx restart
fi

# shellcheck disable=SC2154
